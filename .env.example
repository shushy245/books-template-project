# Copy this file to .env and fill in all values — every variable below is required.
# The values shown match docker-compose.yml and work for local development with no changes.

# ── Backend server ────────────────────────────────────────────────────────────
PORT=3000
OUTBOX_RELAY_INTERVAL_MS=5000

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=reading_room
DB_PASSWORD=reading_room
DB_NAME=reading_room

# ── Test database (docker compose postgres_test service, port 5433) ───────────
DB_TEST_PORT=5433
DB_TEST_USER=reading_room_test
DB_TEST_PASSWORD=reading_room_test
DB_TEST_NAME=reading_room_test
