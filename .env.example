# Copy this file to .env and fill in any values that differ from the defaults.
# The defaults match the credentials in docker-compose.yml — no changes needed for local dev.

# ── Backend server ────────────────────────────────────────────────────────────
PORT=3000

# ── Development database (docker compose postgres service, port 5432) ─────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=reading_room
DB_PASSWORD=reading_room
DB_NAME=reading_room

# ── Test database (docker compose postgres_test service, port 5433) ───────────
DB_TEST_PORT=5433
DB_TEST_USER=reading_room_test
DB_TEST_PASSWORD=reading_room_test
DB_TEST_NAME=reading_room_test
